{
  "manifest_version": 2,

  "author": "Matheus Faustino",
  "developer": {
    "name": "Matheus Faustino",
    "url": "https://github.com/matheusfaustino"
  },

  "name": "TextFast",
  "version": "1.4.0",
  "description": "It lets you replace long words or phrases with easier ones or type emoji faster (e.g. use \"shrug\" to produce ¯\\_[ツ]_/¯).",

  "permissions": ["notifications", "activeTab", "storage", "<all_urls>"],

  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["text-replacer.js"]
    }
  ],

  "icons": {
    "48": "icon.png"
  },
  "browser_action": {
    "default_icon": "icon.png"
  },

  "background": {
    "scripts": ["background.js"]
  },

  "options_ui": {
    "page": "public/config.html",
    "open_in_tab": true
  },

  "browser_specific_settings": {
    "gecko": {
      "id": "textfaster@matheusfaustino.com",
      "strict_min_version": "140.0",
      "data_collection_permissions": {
        "required": ["none"],
        "optional": []
      }
    }
  }
}
